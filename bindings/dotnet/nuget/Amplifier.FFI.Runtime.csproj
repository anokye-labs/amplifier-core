<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Amplifier.FFI.Runtime</PackageId>
    <Version>0.1.0</Version>
    <Authors>anokye-labs</Authors>
    <Description>Native runtime for amplifier-ffi (.NET P/Invoke bridge to amplifier-core).</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- This project has no managed code — it only ships native binaries -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoBuild>true</NoBuild>
    <NoDefaultExcludes>true</NoDefaultExcludes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="runtimes\**\*" Pack="true" PackagePath="runtimes" />
  </ItemGroup>
</Project>
